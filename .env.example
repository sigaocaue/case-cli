# Custom path for the case-cli config file
# Default: ~/.case-cli/config.json
CASE_CLI_CONFIG_PATH=

# Log level (DEBUG, INFO, WARNING, ERROR)
# Default: WARNING
CASE_CLI_LOG_LEVEL=

# Default case style via environment variable (overrides config file)
# Options: upper, lower, snake, kebab, header, camel, pascal, title, random, constant, ada, cobol, train, sentence, dot
CASE_CLI_DEFAULT_CASE=
